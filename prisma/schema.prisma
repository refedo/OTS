model PTSSyncLog {
  id       String @id @default(uuid()) @db.Char(36)
  configId String @db.Char(36)

  // Sync results
  status      String // success, partial, failed
  totalRows   Int
  syncedRows  Int
  skippedRows Int
  errors      Json // Array of error messages
  duration    Int // Milliseconds

  // Timestamp
  syncedAt DateTime @default(now())

