  acknowledgeMethod String?         @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([distributionId, userId])
  @@index([distributionId])
  @@index([userId])
  @@map("ImsDistributionRecipient")
