enum HrLetterType {
  QUESTIONING
  ATTENTION
  FIRST_WARNING
  FINAL_WARNING
  NON_RENEWAL_NOTICE
  DISMISSAL
  CIRCULATION
  WORK_COMMENCEMENT
  SALARY_CERTIFICATE
  LEAVE_NOTICE
  RETURN_FROM_LEAVE
  PROBATION_EVALUATION
  PERFORMANCE_APPRAISAL
  CLEARANCE_FORM
  SALARY_NON_DISCLOSURE
  OTHER
}

enum HrLetterClass {
  INTERNAL
  EXTERNAL
}

enum HrLetterStatus {
  DRAFT
  PENDING_CEO
  APPROVED
  REJECTED
}

enum HrLetterLanguage {
  ARABIC
  ENGLISH
  BILINGUAL
}

model HrLetter {
  id             String           @id @default(uuid()) @db.Char(36)
  letterNumber   String           @unique @db.VarChar(100)
  letterType     HrLetterType
  classification HrLetterClass    @default(INTERNAL)
  language       HrLetterLanguage @default(ARABIC)
  status         HrLetterStatus   @default(PENDING_CEO)
  employeeId     String           @db.Char(36)
  employee       Employee         @relation("EmployeeLetters", fields: [employeeId], references: [id])
  subject        String           @db.VarChar(500)
  content        String?          @db.Text
  contentEn      String?          @db.Text
  purpose        String?          @db.VarChar(500) // e.g. "embassy", "bank" — shown after subject on print
  attachmentUrl  String?          @db.VarChar(1000)
  issuedAt       DateTime         @default(now()) @db.Date
  notes          String?          @db.VarChar(500)

  approvedById    String?   @db.Char(36)
  approvedBy      User?     @relation("HrLetterApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    String?   @db.Char(36)
  rejectedBy      User?     @relation("HrLetterRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?   @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("HrLetterCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("HrLetterUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("HrLetterDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([employeeId])
  @@index([letterType, classification])
  @@index([status])
  @@index([issuedAt])
  @@index([deletedAt])
  @@map("HrLetter")
}

model HrLetterSerialConfig {
  id            String       @id @default(uuid()) @db.Char(36)
  letterType    HrLetterType @unique
  prefix        String       @db.VarChar(20)
  mask          String       @default("{PREFIX}-{YY}-{NNNN}") @db.VarChar(100)
  currentSeq    Int          @default(0)
  lastResetYear Int?
  resetYearly   Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@map("HrLetterSerialConfig")
}

model HrLetterTemplate {
  id          String       @id @default(uuid()) @db.Char(36)
  letterType  HrLetterType
  reasonCode  String       @db.VarChar(80)
  subjectAr   String       @db.VarChar(500)
  subjectEn   String       @db.VarChar(500)
  bodyAr      String?      @db.Text
  bodyEn      String?      @db.Text
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([letterType])
  @@map("HrLetterTemplate")
}

model HrCirculation {
  id                 String              @id @default(uuid()) @db.Char(36)
  circulationNumber  String              @unique @db.VarChar(30)
  subject            String              @db.VarChar(500)
  subjectEn          String?             @db.VarChar(500)
  content            String?             @db.Text
  contentEn          String?             @db.Text
  language           HrLetterLanguage    @default(ARABIC)
  status             HrLetterStatus      @default(PENDING_CEO)
  targetType         String              @default("ALL") @db.VarChar(20)
  attachmentUrl      String?             @db.VarChar(1000)
  issuedAt           DateTime            @default(now()) @db.Date
  notes              String?             @db.VarChar(500)

  approvedById    String?   @db.Char(36)
  approvedBy      User?     @relation("HrCirculationApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    String?   @db.Char(36)
  rejectedBy      User?     @relation("HrCirculationRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?   @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("HrCirculationCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("HrCirculationDeletedBy", fields: [deletedById], references: [id])

  recipients   HrCirculationRecipient[]

  @@index([status])
  @@index([deletedAt])
  @@map("HrCirculation")
}

model HrCirculationRecipient {
  id             String        @id @default(uuid()) @db.Char(36)
  circulationId  String        @db.Char(36)
  circulation    HrCirculation @relation(fields: [circulationId], references: [id], onDelete: Cascade)
  employeeId     String?       @db.Char(36)
  employee       Employee?     @relation("EmployeeCirculationRecipients", fields: [employeeId], references: [id])
  departmentId   String?       @db.Char(36)
  department     Department?   @relation("DepartmentCirculationRecipients", fields: [departmentId], references: [id])
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([circulationId])
  @@index([employeeId])
  @@index([departmentId])
  @@map("HrCirculationRecipient")
}

