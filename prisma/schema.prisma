// ============================================================================
// ENTERPRISE GOVERNANCE SPINE (EGS)
// ============================================================================

// Audit Action Types
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  APPROVE
  REJECT
  SYNC
}

// Audit Severity Levels
enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// AuditLog - Tracks all changes to critical entities with field-level detail
model AuditLog {
  id String @id @default(uuid()) @db.Char(36)

  // Entity reference
  entityType String // "Project", "AssemblyPart", "ProductionLog", etc.
  entityId   String @db.Char(36)

  // Action details
  action  AuditAction
  changes Json? // { fieldName: { old: value, new: value } }

  // Context
  performedById String   @db.Char(36)
  performedBy   User     @relation("AuditLogPerformedBy", fields: [performedById], references: [id])
  performedAt   DateTime @default(now())

  // Tracing
  requestId    String? @db.VarChar(64) // For request tracing
  sourceModule String? @db.VarChar(100) // API, UI, SYNC, AI, etc.

  // Additional context
  reason   String? @db.Text // Optional justification
  metadata Json? // Additional context data

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([performedAt])
  @@index([action])
  @@index([requestId])
}

// EntityVersion - Stores full snapshots of entities for point-in-time recovery
model EntityVersion {
  id String @id @default(uuid()) @db.Char(36)

  // Entity reference
  entityType String // "Project", "Building", "QCInspection", etc.
  entityId   String @db.Char(36)

  // Version info
  versionNumber Int // Incrementing version number per entity
  snapshot      Json // Full entity state at this version

  // Context
  changeReason String?  @db.VarChar(500)
  createdById  String   @db.Char(36)
  createdBy    User     @relation("EntityVersionCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([entityType, entityId, versionNumber])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// System Events - tracks all system activities (enterprise-grade event log)
model SystemEvent {
  id String @id @default(uuid()) @db.Char(36)

  // Event classification
  eventType     String        @db.VarChar(60) // e.g., "PROJECT_STATUS_CHANGED", "AUTH_LOGIN_SUCCESS"
  eventCategory String?       @db.VarChar(30) // New: "PROJECT", "AUTH", "SYSTEM", etc.
  category      String        @db.VarChar(50) // Legacy: "file", "record", "sync", etc.
  severity      AuditSeverity @default(INFO)

  // Who triggered the event
  userId    String? @db.Char(36) // Nullable for system-generated events
  user      User?   @relation("SystemEventUser", fields: [userId], references: [id])
  userName  String? @db.VarChar(100) // Denormalized for performance
  userRole  String? @db.VarChar(50) // Role at time of event
  ipAddress String? @db.VarChar(45) // IPv4 or IPv6
  userAgent String? @db.VarChar(500) // Browser/device info

  // What was affected
  entityType String? @db.VarChar(50) // "Project", "Task", "ProductionLog", etc.
  entityId   String? @db.VarChar(50) // ID of affected entity
  entityName String? @db.VarChar(200) // Human-readable name

  // Project context
  projectId     String?  @db.Char(36)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectNumber String?  @db.VarChar(20) // Denormalized for quick filtering
  buildingId    String?  @db.Char(36) // Building context if applicable

  // Event details
  title         String  @db.VarChar(255) // Legacy: short title
  summary       String? @db.VarChar(500) // Human-readable event summary
  requestId     String? @db.VarChar(64) // For request tracing
  description   String? @db.Text // Legacy: longer details
  details       Json? // Full event data (field changes, before/after, etc.)
  metadata      Json? // Additional context
  changedFields Json? // { field: { old: x, new: y } }

  // Timing
  createdAt DateTime @default(now())
  duration  Int? // Duration in ms (for sync, import operations)

  // Correlation
  correlationId String? @db.VarChar(50) // Groups related events
  parentEventId String? @db.Char(36) // Parent event for hierarchical events
  sessionId     String? @db.VarChar(100) // Links events to user session
  // Using default table name "SystemEvent" where original data exists

  @@index([eventType])
  @@index([eventCategory])
  @@index([category])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([projectId])
  @@index([createdAt])
  @@index([severity])
  @@index([correlationId])
}

// PTS Sync History - tracks all PTS sync operations
model PTSSyncBatch {
  id String @id @default(uuid()) @db.Char(36)

  // Sync details
  syncType String // 'parts', 'logs', 'full'
  status   String // 'completed', 'failed', 'partial'

  // Statistics
  partsCreated Int @default(0)
  partsUpdated Int @default(0)
  logsCreated  Int @default(0)
  logsUpdated  Int @default(0)
  errorsCount  Int @default(0)

  // Projects synced
  projectNumbers Json // Array of project numbers synced

  // Duration and metadata
  durationMs Int // Duration in milliseconds
  metadata   Json? // Additional sync metadata (errors, skipped items, etc.)

  // User who initiated sync
  userId String @db.Char(36)
  user   User   @relation("PTSSyncBatchUser", fields: [userId], references: [id])

  // Rollback tracking
  rolledBack     Boolean   @default(false)
  rolledBackAt   DateTime?
  rolledBackById String?   @db.Char(36)
  rolledBackBy   User?     @relation("PTSSyncBatchRolledBackBy", fields: [rolledBackById], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([rolledBack])
}

// ============================================================================
// PRODUCT BACKLOG MODULE
// ============================================================================

enum BacklogType {
  FEATURE
  BUG
  TECH_DEBT
  PERFORMANCE
  REPORTING
  REFACTOR
  COMPLIANCE
  INSIGHT
}

enum BacklogCategory {
  CORE_SYSTEM
  PRODUCTION
  DESIGN
  DETAILING
  PROCUREMENT
  QC
  LOGISTICS
  FINANCE
  REPORTING
  AI
  GOVERNANCE
  PROJECTS
  HR
}

enum BacklogPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum BacklogStatus {
  IDEA
  UNDER_REVIEW
  APPROVED
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  DROPPED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model ProductBacklogItem {
  id             String          @id @default(uuid()) @db.Char(36)
  code           String          @unique // e.g. OTS-BL-001
  title          String
  description    String          @db.Text
  type           BacklogType
  category       BacklogCategory
  businessReason String          @db.Text // WHY this exists
  expectedValue  String?         @db.Text // qualitative value
  priority       BacklogPriority
  status         BacklogStatus

  affectedModules Json // Array of strings e.g. ["Design","Production","QC","AI"]
  attachments     Json? // Array of {fileName, filePath, fileType, fileSize, uploadedAt}
  riskLevel       RiskLevel
  complianceFlag  Boolean   @default(false)
  linkUrl         String?   @db.VarChar(500) // Optional reference/external URL

  linkedObjectiveId String? @db.Char(36)
  linkedKpiId       String? @db.Char(36)

  createdById   String    @db.Char(36)
  createdAt     DateTime  @default(now())
  approvedById  String?   @db.Char(36)
  approvedAt    DateTime?
  reviewedById  String?   @db.Char(36)
  reviewedAt    DateTime?
  plannedById   String?   @db.Char(36)
  plannedAt     DateTime?
  completedById String?   @db.Char(36)
  completedAt   DateTime?

  // Handler notes (sent to raiser)
  notes Json? // [{ id, content, authorId, authorName, createdAt }]

  // GitHub Integration
  githubIssueNumber Int?
  githubIssueUrl    String?
  githubRepo        String? // owner/repo format
  githubSyncedAt    DateTime?

  tasks       Task[] @relation("BacklogItemTasks")
  createdBy   User   @relation("BacklogItemCreatedBy", fields: [createdById], references: [id])
  approvedBy  User?  @relation("BacklogItemApprovedBy", fields: [approvedById], references: [id])
  reviewedBy  User?  @relation("BacklogItemReviewedBy", fields: [reviewedById], references: [id])
  plannedBy   User?  @relation("BacklogItemPlannedBy", fields: [plannedById], references: [id])
  completedBy User?  @relation("BacklogItemCompletedBy", fields: [completedById], references: [id])

  @@index([type, status, priority])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// KNOWLEDGE CENTER MODULE - Operational Intelligence
// ============================================================================

enum KnowledgeEntryType {
  CHALLENGE
  ISSUE
  LESSON
  BEST_PRACTICE
}

enum KnowledgeStatus {
  Open
  InProgress
  PendingValidation
  Validated
  Archived
}

enum KnowledgeSeverity {
  Low
  Medium
  High
  Critical
}

enum KnowledgeProcess {
  Design
  Detailing
  Procurement
  Production
  QC
  Erection
}

model KnowledgeEntry {
  id             String             @id @default(uuid()) @db.Char(36)
  type           KnowledgeEntryType
  title          String
  summary        String             @db.Text
  rootCause      String?            @db.Text
  resolution     String?            @db.Text
  recommendation String?            @db.Text

  severity KnowledgeSeverity
  status   KnowledgeStatus
  process  KnowledgeProcess

  // Optional project/building/work unit linkage
  projectId  String? @db.Char(36)
  buildingId String? @db.Char(36)
  workUnitId String? @db.Char(36)

  // Evidence links (stored as JSON array of references)
  evidenceLinks Json? // Array of {type: "NCR"|"ProductionLog"|"QC"|"RFI", id: string, label: string}

  // Tags for categorization and search
  tags Json? // Array of strings

  // File attachments
  attachments Json? // Array of {fileName: string, filePath: string, uploadedAt: string}

  // Ownership and validation
  reportedById  String  @db.Char(36)
  ownerId       String? @db.Char(36)
  validatedById String? @db.Char(36)

  // Promotion tracking (Phase 2)
  promotionSourceIssueId String?          @db.Char(36)
  promotedFromIssue      KnowledgeEntry?  @relation("IssuePromotion", fields: [promotionSourceIssueId], references: [id], onDelete: SetNull)
  promotedToLessons      KnowledgeEntry[] @relation("IssuePromotion")

  // Relations
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  building    Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  workUnit    WorkUnit? @relation(fields: [workUnitId], references: [id], onDelete: SetNull)
  reportedBy  User      @relation("KnowledgeReportedBy", fields: [reportedById], references: [id])
  owner       User?     @relation("KnowledgeOwner", fields: [ownerId], references: [id])
  validatedBy User?     @relation("KnowledgeValidatedBy", fields: [validatedById], references: [id])

  // Usage tracking (Phase 2)
  applications KnowledgeApplication[]

  // Risk pattern linkage (Phase 3)
  riskPatterns RiskPatternEntry[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  validatedAt DateTime?

  @@index([type])
  @@index([status])
  @@index([process])
  @@index([severity])
  @@index([projectId])
  @@index([buildingId])
  @@index([workUnitId])
  @@index([reportedById])
  @@index([validatedById])
  @@index([createdAt])
}

// Phase 2: Usage Tracking
model KnowledgeApplication {
  id               String  @id @default(uuid()) @db.Char(36)
  knowledgeEntryId String  @db.Char(36)
  projectId        String  @db.Char(36)
  workUnitId       String? @db.Char(36)
  appliedById      String  @db.Char(36)
  outcomeNotes     String? @db.Text

  knowledgeEntry KnowledgeEntry @relation(fields: [knowledgeEntryId], references: [id], onDelete: Cascade)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workUnit       WorkUnit?      @relation(fields: [workUnitId], references: [id], onDelete: SetNull)
  appliedBy      User           @relation("KnowledgeApplicationUser", fields: [appliedById], references: [id])

  appliedAt DateTime @default(now())

  @@index([knowledgeEntryId])
  @@index([projectId])
  @@index([appliedById])
  @@index([appliedAt])
}

// Phase 3: Risk Pattern Detection (System-Derived)
enum RiskPatternStatus {
  Observed
  Escalated
  Addressed
}

model RiskPattern {
  id              String            @id @default(uuid()) @db.Char(36)
  patternKey      String            @unique // Hash of process + tags + category
  process         KnowledgeProcess
  tags            Json // Array of common tags
  occurrenceCount Int
  timeWindow      String // e.g., "6 months"
  status          RiskPatternStatus @default(Observed)

  // Linked entries
  linkedEntries RiskPatternEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([process])
  @@index([status])
  @@index([occurrenceCount])
  @@index([createdAt])
}

// Junction table for RiskPattern and KnowledgeEntry
model RiskPatternEntry {
  id               String @id @default(uuid()) @db.Char(36)
  riskPatternId    String @db.Char(36)
  knowledgeEntryId String @db.Char(36)

  riskPattern    RiskPattern    @relation(fields: [riskPatternId], references: [id], onDelete: Cascade)
  knowledgeEntry KnowledgeEntry @relation(fields: [knowledgeEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([riskPatternId, knowledgeEntryId])
  @@index([riskPatternId])
  @@index([knowledgeEntryId])
}

// ============================================
// Detailed Project Planner (MS Project-style)
// ============================================

model PlannerProject {
  id          String    @id @default(uuid()) @db.Char(36)
  name        String
  description String?   @db.Text
  projectId   String?   @db.Char(36) // Optional link to existing OTS Project
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  status      String    @default("Active") // Active, Completed, On Hold, Archived

  tasks PlannerTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

model PlannerTask {
  id               String  @id @default(uuid()) @db.Char(36)
  plannerProjectId String  @db.Char(36)
  parentId         String? @db.Char(36)

  name      String
  level     String // "building", "activity", "sub_activity", "sub_sub_activity"
  sortOrder Int    @default(0)

  // Scheduling
  startDate    DateTime? @db.Date
  endDate      DateTime? @db.Date
  durationDays Decimal?  @db.Decimal(10, 2) // e.g., 7.38 days
  progress     Int       @default(0) // 0-100 percentage

  // Task properties
  isSummary   Boolean @default(false)
  isMilestone Boolean @default(false)
  taskMode    String  @default("auto") // "auto" or "manual"

  // Relations
  plannerProject PlannerProject @relation(fields: [plannerProjectId], references: [id], onDelete: Cascade)
  parent         PlannerTask?   @relation("PlannerTaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       PlannerTask[]  @relation("PlannerTaskHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plannerProjectId])
  @@index([parentId])
  @@index([sortOrder])
  @@index([level])
}

// ============================================================================
// SUPPLY CHAIN MODULE — LCR (Least Cost Routing)
// ============================================================================

model LcrEntry {
  id               String   @id @default(uuid()) @db.Char(36)
  sheetRowId       String   @unique @db.VarChar(100)
  rowHash          String   @db.VarChar(32)
  syncedAt         DateTime
  isDeleted        Boolean  @default(false)
  resolutionStatus String   @default("pending") @db.VarChar(20)

  // Identity
  sn              String?   @db.VarChar(50)
  projectNumber   String?   @db.VarChar(50)
  projectId       String?   @db.Char(36)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  itemLabel       String?   @db.VarChar(500)
  productId       Int?
  qty             Decimal?  @db.Decimal(15, 3)
  amount          Decimal?  @db.Decimal(15, 2)
  status          String?   @db.VarChar(100)
  buildingNameRaw String?   @db.VarChar(255)
  buildingId      String?   @db.Char(36)
  building        Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  mrfNumber       String?   @db.VarChar(100)

  // Timeline
  requestDate    DateTime? @db.Date
  neededFromDate DateTime? @db.Date
  neededToDate   DateTime? @db.Date
  buyingDate     DateTime? @db.Date
  receivingDate  DateTime? @db.Date

  // Purchase
  poNumber     String?  @db.VarChar(100)
  dnNumber     String?  @db.VarChar(100)
  awardedToRaw String?  @db.VarChar(255)
  supplierId   Int?
  weight       Decimal? @db.Decimal(15, 3)
  totalWeight  Decimal? @db.Decimal(15, 3)
  thickness    String?  @db.VarChar(100)
  targetPrice  Decimal? @db.Decimal(15, 2)

  // LCR1
  totalLcr1       Decimal? @db.Decimal(15, 2)
  ratio1to2Lcr1   Decimal? @db.Decimal(10, 4)
  lcr1            String?  @db.VarChar(255)
  lcr1Amount      Decimal? @db.Decimal(15, 2)
  lcr1PricePerTon Decimal? @db.Decimal(15, 2)

  // LCR2
  totalLcr2       Decimal? @db.Decimal(15, 2)
  lcr2            String?  @db.VarChar(255)
  lcr2Amount      Decimal? @db.Decimal(15, 2)
  lcr2PricePerTon Decimal? @db.Decimal(15, 2)

  // LCR3
  lcr3            String?  @db.VarChar(255)
  lcr3Amount      Decimal? @db.Decimal(15, 2)
  lcr3PricePerTon Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([buildingId])
  @@index([status])
  @@index([resolutionStatus])
  @@index([isDeleted])
  @@index([neededToDate])
  @@index([receivingDate])
  @@index([syncedAt])
  @@map("lcr_entries")
}

model LcrAliasMap {
  id          String   @id @default(uuid()) @db.Char(36)
  aliasText   String   @db.VarChar(255)
  entityType  String   @db.VarChar(20)
  entityId    String   @db.VarChar(36)
  notes       String?  @db.Text
  createdById String   @db.Char(36)
  createdBy   User     @relation("LcrAliasMapCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([aliasText, entityType])
  @@index([entityType])
  @@map("lcr_alias_map")
}

model LcrSyncLog {
  id             String   @id @default(uuid()) @db.Char(36)
  status         String   @db.VarChar(20)
  triggeredBy    String   @db.VarChar(20)
  totalRows      Int      @default(0)
  rowsInserted   Int      @default(0)
  rowsUpdated    Int      @default(0)
  rowsUnchanged  Int      @default(0)
  rowsDeleted    Int      @default(0)
  pendingAliases Int      @default(0)
  durationMs     Int      @default(0)
  errorMessage   String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("lcr_sync_logs")
}

// Daily aggregates for system events — written by event-cleanup cron after archiving
model SystemEventSummary {
  id            Int      @id @default(autoincrement())
  summaryDate   DateTime @db.Date
  eventCategory String?  @db.VarChar(30)
  eventType     String?  @db.VarChar(60)
  severity      String   @db.VarChar(20)
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([summaryDate, eventCategory, eventType, severity])
  @@index([summaryDate])
  @@map("system_event_summaries")
}

// ============================================================================
// OPEN-AUDIT — External Compliance Mirror
// Tracks every governance event forwarded to the external open-audit store.
// A failed forward is retried up to 3 times; after that it is marked 'failed'.
// ============================================================================

model OpenAuditMirrorLog {
  id String @id @default(uuid()) @db.Char(36)

  // Source OTS audit entry reference
  auditLogId String @db.Char(36)

  // open-audit event payload (denormalized for replay/debugging)
  actorId  String @db.VarChar(100)
  action   String @db.VarChar(60)
  entity   String @db.VarChar(100)
  entityId String @db.VarChar(100)
  metadata Json?

  // Delivery tracking
  status        String    @default("pending") @db.VarChar(20) // pending | delivered | failed
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  deliveredAt   DateTime?
  errorMessage  String?   @db.Text

  createdAt DateTime @default(now())

  @@index([status])
  @@index([auditLogId])
  @@index([createdAt])
  @@map("open_audit_mirror_logs")
}

// ============================================================================
// NEXTCLOUD — Document & File Management
// Tracks every file uploaded to Nextcloud so OTS can reference it by
// the Nextcloud remote path without storing the binary locally.
// ============================================================================

model NextcloudFile {
  id String @id @default(uuid()) @db.Char(36)

  // Nextcloud remote path, e.g. "/OTS/documents/project-254/drawing.pdf"
  remotePath String @db.VarChar(1000)

  // Mirrored metadata (avoids re-PROPFIND on every request)
  fileName     String    @db.VarChar(255)
  fileSize     Int?
  mimeType     String?   @db.VarChar(100)
  etag         String?   @db.VarChar(100)
  lastModified DateTime?

  // Which OTS entity owns this file
  entityType String @db.VarChar(60) // Document | DocumentSubmission | WPS | ITP | etc.
  entityId   String @db.Char(36)

  // Optional share link
  shareToken     String?   @db.VarChar(64)
  shareUrl       String?   @db.VarChar(500)
  shareExpiresAt DateTime?

  // Audit
  uploadedById String   @db.Char(36)
  uploadedBy   User     @relation("NextcloudFileUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([remotePath])
  @@map("nextcloud_files")
}

// ============================================================================
// LIBRE MES — Manufacturing Execution & Performance Monitoring
// ============================================================================

// Tracks each push of a WorkOrder to Libre MES PostgreSQL.
model LibreMesOrderSync {
  id String @id @default(uuid()) @db.Char(36)

  workOrderId String    @unique @db.Char(36)
  workOrder   WorkOrder @relation("WorkOrderLibreSync", fields: [workOrderId], references: [id], onDelete: Cascade)

  libreOrderId String? @db.VarChar(100)
  libreStatus  String? @db.VarChar(50)

  syncStatus   String    @default("pending") @db.VarChar(20) // pending | synced | failed | stale
  lastSyncAt   DateTime?
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([syncStatus])
  @@index([lastSyncAt])
  @@map("libre_mes_order_syncs")
}

// Stores OEE / production metrics pulled back from Libre MES InfluxDB.
model LibreMesMetricSnapshot {
  id String @id @default(uuid()) @db.Char(36)

  workOrderId    String? @db.Char(36)
  assemblyPartId String? @db.Char(36)
  libreOrderId   String? @db.VarChar(100)

  // InfluxDB measurement source
  influxBucket  String @db.VarChar(60) // availability | performance | quality | orderPerformance
  influxMeasure String @db.VarChar(60)

  // OEE components (0.0000 – 1.0000)
  availability Decimal? @db.Decimal(5, 4)
  performance  Decimal? @db.Decimal(5, 4)
  quality      Decimal? @db.Decimal(5, 4)
  oee          Decimal? @db.Decimal(5, 4)

  // Production counts
  plannedQty Int?
  actualQty  Int?
  scrapQty   Int?

  // Time window this snapshot covers
  periodStart DateTime
  periodEnd   DateTime

  rawPayload Json?
  pulledAt   DateTime @default(now())

  @@index([workOrderId])
  @@index([influxBucket])
  @@index([periodStart])
  @@map("libre_mes_metric_snapshots")
}

// Audit log for all Libre MES sync operations (push + pull).
model LibreMesSyncLog {
  id           String   @id @default(uuid()) @db.Char(36)
  operation    String   @db.VarChar(20) // push_orders | pull_metrics | full_sync
  status       String   @db.VarChar(20) // success | partial | failed
  ordersTotal  Int      @default(0)
  ordersSynced Int      @default(0)
  metricsTotal Int      @default(0)
  durationMs   Int      @default(0)
  errorMessage String?  @db.Text
  triggeredBy  String   @db.VarChar(20) // manual | cron
  userId       String?  @db.Char(36)
  createdAt    DateTime @default(now())

  @@index([status])
  @@index([operation])
  @@index([createdAt])
  @@map("libre_mes_sync_logs")
}

// ============================================================================
// HR MODULE — PHASE 1: HR FOUNDATION & MASTER DATA
// ============================================================================
// Spec: OTS-MSS-HR-PAYROLL-v1. OTS is the single source of truth for the
// employee master. Dolibarr llx_user is mirrored one-way (read-only) via the
// sync service until the future Leave spec ships and Dolibarr is fully sunset
// for HR. `employmentId` is the authoritative join key to Dolibarr (rowid).
// ============================================================================

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum CardStatus {
  ACTIVE
  LOST
  RETURNED
  SUSPENDED
}

enum DolibarrEmployeeSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model Employee {
  id String @id @default(uuid()) @db.Char(36)

  // Identity — employmentId mirrors Dolibarr llx_user.rowid (cast to string).
  // This is the join key used by the PTS attendance sheet (Phase 2) as well.
  employmentId  String         @unique @db.VarChar(64)
  fullNameEn    String         @db.VarChar(255)
  fullNameAr    String?        @db.VarChar(255)
  nationalId    String?        @unique @db.VarChar(32) // Iqama / National ID (WPS)
  nationality   String?        @db.VarChar(80)
  dateOfBirth   DateTime?      @db.Date
  dateOfJoining DateTime       @db.Date
  dateOfLeaving DateTime?      @db.Date
  status        EmployeeStatus @default(ACTIVE)
  // 18.7.0 — `occupation` is the canonical "Position Title" field. It is
  // surfaced in the UI as "Position Title" but the column name stays
  // `occupation` so the existing HrOccupation catalogue + its API
  // (/api/hr/occupations) stay stable. The legacy free-text `trade` column
  // was dropped in 18.7.0 (its values were copied into `occupation` first
  // by prisma/manual_migrations/migrate_trade_to_occupation.sql) and the
  // Dolibarr sync now writes `apiUser.job` straight into `occupation`.
  // `section` is a UI dropdown ("Preparation" / "Fabrication" / "Other").
  // `department` is an FK to the existing `Department` model (same catalogue
  // used by `User.departmentId`). The legacy free-text `department` column
  // is retained for audit of the Dolibarr `options_department` extrafield;
  // new UI writes `departmentId`.
  occupation    String?        @db.VarChar(120)
  section       String?        @db.VarChar(60)
  division      String?        @db.VarChar(80) // 18.4.0 — managed via HrDivision
  department    String?        @db.VarChar(120) // legacy — Dolibarr extrafield label, retained for audit
  departmentId  String?        @db.Char(36)
  departmentRef Department?    @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  jobTitleEn    String?        @db.VarChar(200)
  jobTitleAr    String?        @db.VarChar(200)

  reportsToId  String?    @db.Char(36)
  reportsTo    Employee?  @relation("EmployeeHierarchy", fields: [reportsToId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeHierarchy")

  // Compensation (packageSalary is derived — basic + all allowances — and NOT stored)
  basicSalary        Decimal @db.Decimal(12, 2)
  housingAllowance   Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  mobileAllowance    Decimal @default(0) @db.Decimal(12, 2)
  foodAllowance      Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)

  // 18.5.0 — GOSI (General Organization for Social Insurance).
  // `isGosiSubject` is an explicit flag (can be true for non-Saudis too when
  // the employer has opted in). `gosiSalary` is the salary the GOSI 10%/12%
  // is calculated on, which may differ from `basicSalary` — HR registers
  // a separate figure with GOSI. When null and `isGosiSubject` is true,
  // the calculator falls back to `basicSalary + housingAllowance`.
  isGosiSubject Boolean  @default(false)
  gosiSalary    Decimal? @db.Decimal(12, 2)

  // Work pattern
  standardDailyHours Int @default(8)
  workWeekDaysCount  Int @default(6) // Sat–Thu

  // Banking (for WPS SIF)
  bankName String? @db.VarChar(200)
  bankIban String? @db.VarChar(34)

  // Extended Dolibarr extrafields (19.5.0)
  employeeNo      String?   @db.VarChar(20)
  boarderNumber   String?   @db.VarChar(255)
  maritalStatus   String?   @db.VarChar(50)
  occupationAr    String?   @db.VarChar(100)
  gosiSubscriptionNo String? @db.VarChar(100)
  contractEndDate DateTime? @db.Date
  contractDuration String?  @db.VarChar(100)
  passportNumber  String?   @db.VarChar(100)
  iqamaUrl        String?   @db.VarChar(255)
  passportUrl     String?   @db.VarChar(255)
  sponsorNumber   String?   @db.VarChar(30)
  contractType    String?   @db.VarChar(100)
  workingLocation String?   @db.VarChar(100)
  transferType    String?   @db.VarChar(100)
  gender          String?   @db.VarChar(10) // MALE or FEMALE — synced from Dolibarr

  // Sync state — set by syncDolibarrEmployees service
  lastSyncedFromDolibarrAt DateTime?
  // JSON array of column names that have been edited via the OTS UI after sync;
  // the sync service skips these fields on update (preserve-on-edit policy).
  // Newly-created rows always populate all fields from Dolibarr regardless.
  manuallyEditedFields     Json?

  // 1:1 back-ref from User (identity reconciliation). Nullable — most
  // Employees will never have an OTS login.
  otsUser User? @relation("UserEmployee")

  // Phase 2: attendance / leaves / overtime from Google Sheet
  attendanceRecords AttendanceRecord[]

  // Phase 2.5: attendance candidates resolved onto this employee
  resolvedAttendanceCandidates AttendanceMappingCandidate[] @relation("resolvedAttendanceCandidates")

  // Phase 3 — Leaves / Payroll / EOS back-relations
  leaveRequests      LeaveRequest[]      @relation("EmployeeLeaveRequests")
  leaveBalances      LeaveBalance[]      @relation("EmployeeLeaveBalances")
  payrollLines       PayrollLine[]       @relation("EmployeePayrollLines")
  payrollAdjustments PayrollAdjustment[] @relation("EmployeePayrollAdjustments")
  endOfServiceAward  EndOfServiceAward?  @relation("EmployeeEosAward")

  // 18.9.0 — Employment & compensation history (redesign Phase 1)
  positionHistory EmployeePositionHistory[] @relation("EmployeePositionHistoryEmployee")
  salaryHistory   EmployeeSalaryHistory[]   @relation("EmployeeSalaryHistoryEmployee")

  // 18.10.0 — Loans & Custodies
  loans     Loan[]    @relation("EmployeeLoans")
  custodies Custody[] @relation("EmployeeCustodies")

  // 18.12.0 — Asset Management
  assetAssignments AssetAssignment[]  @relation("EmployeeAssetAssignments")
  violations       TrafficViolation[] @relation("EmployeeViolations")

  // 18.14.0 — Contracts & Documents
  contracts Contract[] @relation("EmployeeContracts")

  // 18.16.0 — Letters & Correspondence
  letters HrLetter[] @relation("EmployeeLetters")

  // 19.16.0 — Circulations
  circulationRecipients HrCirculationRecipient[] @relation("EmployeeCirculationRecipients")

  // Audit fields (AssemblyPart pattern)
  createdById  String    @db.Char(36)
  createdBy    User      @relation("EmployeeCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("EmployeeUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("EmployeeDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([status])
  @@index([department])
  @@index([departmentId])
  @@index([section])
  @@index([occupation])
  @@index([deletedAt])
}

// 18.9.0 — Employment & compensation history (HR/Payroll Phase 1)
// One "open" row (effectiveTo = null) per employee at a time per history type.
// Earlier rows have effectiveTo set to the day before the successor's
// effectiveFrom so the timeline is contiguous.

enum EmployeePositionChangeReason {
  HIRED
  PROMOTED
  TRANSFERRED
  DEMOTED
  ROLE_CHANGE
  RESIGNED
  TERMINATED
  REHIRED
}

model EmployeePositionHistory {
  id         String   @id @default(uuid()) @db.Char(36)
  employeeId String   @db.Char(36)
  employee   Employee @relation("EmployeePositionHistoryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date // null = currently active

  positionTitle String  @db.VarChar(200) // "Fabricator", "Foreman", etc.
  section       String? @db.VarChar(60)
  division      String? @db.VarChar(80)
  departmentId  String? @db.Char(36)
  department    Department? @relation("EmployeePositionHistoryDepartment", fields: [departmentId], references: [id])

  reason EmployeePositionChangeReason
  notes  String? @db.VarChar(1000)

  // 1:many — a position change may anchor one or more salary changes
  // happening on the same date (e.g. promotion + raise).
  salaryHistory EmployeeSalaryHistory[] @relation("EmployeeSalaryHistoryPosition")

  // Audit (AssemblyPart pattern)
  createdById  String    @db.Char(36)
  createdBy    User      @relation("EmployeePositionHistoryCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("EmployeePositionHistoryUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("EmployeePositionHistoryDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([employeeId])
  @@index([employeeId, effectiveFrom])
  @@index([effectiveTo])
  @@index([deletedAt])
}

enum EmployeeSalaryChangeReason {
  HIRED
  ANNUAL_INCREMENT
  PROMOTION
  ADJUSTMENT
  COLA
  CORRECTION
  DEMOTION
}

// Raises follow a cycle: DRAFT → PENDING_HR → PENDING_CEO → APPROVED (or REJECTED).
// Only an APPROVED row is considered "effective" by the payroll calculator.
// A HIRED row is seeded as APPROVED directly by the backfill script.
enum EmployeeSalaryApprovalStatus {
  DRAFT
  PENDING_HR
  PENDING_CEO
  APPROVED
  REJECTED
}

model EmployeeSalaryHistory {
  id         String   @id @default(uuid()) @db.Char(36)
  employeeId String   @db.Char(36)
  employee   Employee @relation("EmployeeSalaryHistoryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)

  // Optional FK tying a raise to a position change that happened at the same
  // time (e.g. promoted from Fabricator → Foreman with a basic bump).
  positionHistoryId String?                  @db.Char(36)
  positionHistory   EmployeePositionHistory? @relation("EmployeeSalaryHistoryPosition", fields: [positionHistoryId], references: [id], onDelete: SetNull)

  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date // null = currently active (and APPROVED)

  // Compensation snapshot — mirrors Employee.* but frozen at the effective date.
  basicSalary        Decimal @db.Decimal(12, 2)
  housingAllowance   Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  mobileAllowance    Decimal @default(0) @db.Decimal(12, 2)
  foodAllowance      Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)

  reason EmployeeSalaryChangeReason
  notes  String? @db.VarChar(1000)

  // Approval workflow — CEO is the final signer for every raise.
  status        EmployeeSalaryApprovalStatus @default(DRAFT)
  submittedAt   DateTime?
  submittedById String?                      @db.Char(36)
  submittedBy   User?                        @relation("EmployeeSalaryHistorySubmittedBy", fields: [submittedById], references: [id])
  hrApprovedAt  DateTime?
  hrApprovedById String?                     @db.Char(36)
  hrApprovedBy  User?                        @relation("EmployeeSalaryHistoryHrApprover", fields: [hrApprovedById], references: [id])
  ceoApprovedAt DateTime?
  ceoApprovedById String?                    @db.Char(36)
  ceoApprovedBy User?                        @relation("EmployeeSalaryHistoryCeoApprover", fields: [ceoApprovedById], references: [id])
  rejectedAt    DateTime?
  rejectedById  String?                      @db.Char(36)
  rejectedBy    User?                        @relation("EmployeeSalaryHistoryRejectedBy", fields: [rejectedById], references: [id])
  rejectReason  String?                      @db.VarChar(1000)

  // Audit (AssemblyPart pattern)
  createdById  String    @db.Char(36)
  createdBy    User      @relation("EmployeeSalaryHistoryCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("EmployeeSalaryHistoryUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("EmployeeSalaryHistoryDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([employeeId])
  @@index([employeeId, effectiveFrom])
  @@index([status])
  @@index([effectiveTo])
  @@index([deletedAt])
}

model Agency {
  id            String       @id @default(uuid()) @db.Char(36)
  nameEn        String       @db.VarChar(255)
  nameAr        String?      @db.VarChar(255)
  contactPerson String?      @db.VarChar(200)
  contactPhone  String?      @db.VarChar(40)
  contractRef   String?      @db.VarChar(120)
  contractStart DateTime?    @db.Date
  contractEnd   DateTime?    @db.Date
  status        AgencyStatus @default(ACTIVE)

  slots          ManpowerSlot[]
  invoiceDrafts  ManpowerInvoiceDraft[]

  // Dolibarr third-party ID (fournisseur) for pushing vendor invoices
  dolibarrThirdPartyId String? @db.VarChar(40)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("AgencyCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("AgencyUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("AgencyDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([status])
  @@index([deletedAt])
}

model ManpowerSlot {
  id         String     @id @default(uuid()) @db.Char(36)
  agencyId   String     @db.Char(36)
  slotCode   String     @unique @db.VarChar(40) // SH-W01, SH-F02, AHR-W03, etc.
  trade      String     @db.VarChar(120) // Welder, Fabricator, Helper, Painter
  hourlyRate Decimal    @db.Decimal(10, 2)
  cardStatus CardStatus @default(ACTIVE)
  notes      String?    @db.VarChar(500)

  agency Agency @relation(fields: [agencyId], references: [id])

  // Phase 2: attendance / leaves / overtime from Google Sheet
  attendanceRecords AttendanceRecord[]

  // Phase 4: billing invoice lines
  invoiceLines ManpowerInvoiceLine[]

  createdById  String    @db.Char(36)
  createdBy    User      @relation("ManpowerSlotCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("ManpowerSlotUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("ManpowerSlotDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([agencyId, cardStatus])
  @@index([trade])
  @@index([deletedAt])
}

// Dedicated sync log for the Dolibarr → OTS employee mirror. Matches the
// pattern of existing PTSSyncLog / LcrSyncLog / LibreMesSyncLog.
model DolibarrEmployeeSyncLog {
  id               String                     @id @default(uuid()) @db.Char(36)
  startedAt        DateTime                   @default(now())
  finishedAt       DateTime?
  triggeredById    String                     @db.Char(36)
  triggeredBy      User                       @relation("DolibarrEmployeeSyncLogTriggeredBy", fields: [triggeredById], references: [id])
  status           DolibarrEmployeeSyncStatus
  rowsRead         Int                        @default(0)
  rowsCreated      Int                        @default(0)
  rowsUpdated      Int                        @default(0)
  rowsSkipped      Int                        @default(0)
  fieldsPreserved  Int                        @default(0) // count of field-level skips due to manuallyEditedFields
  linksEstablished Int                        @default(0) // User.employeeId links backfilled this run
  hardErrors       Json? // [{ employmentId, message }]
  softWarnings     Json? // [{ employmentId, field, message }]
  apiResponseMs    Int?

  @@index([status])
  @@index([startedAt])
}

// 18.6.0 — per-run audit log for the Dolibarr `holidays` → OTS LeaveRequest
// mirror. One row per sync invocation, whether triggered manually from
// /hr/leaves or automatically by the scheduler.
model DolibarrLeaveSyncLog {
  id                       String                  @id @default(uuid()) @db.Char(36)
  startedAt                DateTime                @default(now())
  finishedAt               DateTime?
  triggeredById            String                  @db.Char(36)
  triggeredBy              User                    @relation("DolibarrLeaveSyncLogTriggeredBy", fields: [triggeredById], references: [id])
  triggerSource            String                  @default("manual") @db.VarChar(20) // "manual" | "cron"
  status                   DolibarrLeaveSyncStatus
  rowsRead                 Int                     @default(0)
  rowsCreated              Int                     @default(0)
  rowsUpdated              Int                     @default(0)
  rowsSkipped              Int                     @default(0)
  employeesNotFound        Int                     @default(0) // fk_user not matched to an Employee
  typesNotMapped           Int                     @default(0) // fk_type had no OTS LeaveType.code mapping
  attendanceDaysOverridden Int                     @default(0) // sheet attendance days covered by a Dolibarr leave
  hardErrors               Json? // [{ dolibarrId, message }]
  softWarnings             Json? // [{ dolibarrId, field, message }]
  apiResponseMs            Int?

  @@index([status])
  @@index([startedAt])
}

// Simple key/value system configuration store. Separate from the legacy
// single-row `SystemSettings` model which holds strongly-typed application
// settings. Used for feature flags and gate flags that don't deserve their
// own column (e.g. identityReconciliationComplete).
model SystemConfig {
  id          String   @id @default(uuid()) @db.Char(36)
  key         String   @unique @db.VarChar(120)
  value       String   @db.Text
  description String?  @db.VarChar(500)
  updatedById String?  @db.Char(36)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
}

// ============================================================================
// Phase 2 of OTS-MSS-HR-PAYROLL-v1 — Attendance, Leaves, Overtime
// One-way Google Sheet → OTS mirror. The sheet stays source of truth for
// corrections; OTS never writes back.
// ============================================================================

enum WorkerType {
  EMPLOYEE // FK to Employee (direct hire, linked to Dolibarr)
  MANPOWER_SLOT // FK to ManpowerSlot (agency worker)
}

enum AttendanceStatus {
  PRESENT // worked any positive number of hours
  ABSENT_WITH_PERMISSION // AP — approved absence, no hours worked
  ABSENT_NO_PERMISSION // ANP — unauthorised no-show
  ANNUAL_VACATION // AV — approved annual leave
  SICK_LEAVE // SL — sick leave
  WEEKEND // Friday rest day, no work
  PUBLIC_HOLIDAY // On a PublicHoliday row and no hours worked
  UNKNOWN // Cell couldn't be parsed — surfaced as soft warning
}

enum AttendanceSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// One row per (worker, date). Mirrors the Google Sheet attendance tab.
// Uniqueness is enforced per worker per day — re-sync updates in place.
model AttendanceRecord {
  id             String        @id @default(uuid()) @db.Char(36)
  workerType     WorkerType
  employeeId     String?       @db.Char(36)
  employee       Employee?     @relation(fields: [employeeId], references: [id])
  manpowerSlotId String?       @db.Char(36)
  manpowerSlot   ManpowerSlot? @relation(fields: [manpowerSlotId], references: [id])

  date            DateTime         @db.Date
  status          AttendanceStatus
  regularHours    Decimal          @default(0) @db.Decimal(5, 2)
  overtimeHours   Decimal          @default(0) @db.Decimal(5, 2)
  otMultiplier    Decimal          @default(1.00) @db.Decimal(3, 2) // 1.5 for Friday OT, 1.0 for weekday
  isFriday        Boolean          @default(false)
  isPublicHoliday Boolean          @default(false)

  // Raw cell values — kept verbatim for audit and re-parsing on schema changes.
  rawCellA String? @db.Text // A/P column raw cell (code, hours, or comment)
  rawCellP String? @db.Text // O.T column raw cell (hours); null for manpower slots (1 col)

  // sha256(employmentId|date|rawCellA|rawCellP) — lets the sync skip unchanged rows.
  sourceRowHash String @db.Char(64)

  lastImportBatchId String?  @db.Char(36)
  lastImportedAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A worker can only have one record per date. The composite unique includes
  // both FK columns so Prisma can validate at the client layer too.
  @@unique([workerType, employeeId, manpowerSlotId, date], name: "uniq_attendance_worker_date")
  @@index([date])
  @@index([employeeId, date])
  @@index([manpowerSlotId, date])
  @@index([status])
}

// KSA public holidays. Manual CRUD for now; Phase 3 may pull from a feed.
model PublicHoliday {
  id          String    @id @default(uuid()) @db.Char(36)
  date        DateTime  @unique @db.Date
  endDate     DateTime? @db.Date // optional end date for multi-day holidays
  nameEn      String    @db.VarChar(200)
  nameAr      String?   @db.VarChar(200)
  isRecurring Boolean   @default(false) // annual holiday (e.g. National Day) vs one-off

  createdById String    @db.Char(36)
  createdBy   User      @relation("PublicHolidayCreatedBy", fields: [createdById], references: [id])
  updatedById String?   @db.Char(36)
  updatedBy   User?     @relation("PublicHolidayUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?   @db.Char(36)
  deletedBy   User?     @relation("PublicHolidayDeletedBy", fields: [deletedById], references: [id])

  @@index([deletedAt])
}

// Per-run log for the Google Sheet attendance sync. Mirrors DolibarrEmployeeSyncLog.
model GoogleSheetAttendanceSyncLog {
  id                  String               @id @default(uuid()) @db.Char(36)
  startedAt           DateTime             @default(now())
  finishedAt          DateTime?
  triggeredById       String               @db.Char(36)
  triggeredBy         User                 @relation("GoogleSheetAttendanceSyncLogTriggeredBy", fields: [triggeredById], references: [id])
  status              AttendanceSyncStatus
  spreadsheetId       String               @db.VarChar(100)
  tabName             String               @db.VarChar(100)
  rowsRead            Int                  @default(0)
  rowsCreated         Int                  @default(0)
  rowsUpdated         Int                  @default(0)
  rowsUnchanged       Int                  @default(0)
  // Phase 2.5 — Employee attribute sync counters (occupation/section/department
  // pulled from sheet header rows, honoring manuallyEditedFields).
  occupationsUpdated  Int                  @default(0)
  sectionsUpdated     Int                  @default(0)
  departmentsUpdated  Int                  @default(0)
  preservedFieldSkips Int                  @default(0) // field-level skips due to manuallyEditedFields
  // Phase 2.5 — mapping candidate counters
  candidatesCreated   Int                  @default(0)
  candidatesResolved  Int                  @default(0) // existing RESOLVED candidates that matched this run
  candidatesIgnored   Int                  @default(0) // existing IGNORED candidates silently skipped
  employeeOrphans     Json? // [{ identifier, name, firstRowIndex }] — kept for audit
  slotOrphans         Json? // [{ identifier, name, firstRowIndex }] — kept for audit
  hardErrors          Json? // [{ row, column, message }]
  softWarnings        Json? // [{ row, column, message }]
  durationMs          Int?

  @@index([status])
  @@index([startedAt])
}

/// HR Phase 2.5 — mapping candidates for attendance rows that cannot be
/// resolved to a known Employee/ManpowerSlot. Each row represents a unique
/// (identifier, workerType) pair encountered in the Google Sheet. Users can
/// link the candidate to an existing Employee or permanently ignore it.
enum AttendanceMappingStatus {
  UNMAPPED
  RESOLVED
  IGNORED
}

model AttendanceMappingCandidate {
  id                  String                  @id @default(uuid()) @db.Char(36)
  identifier          String                  @db.VarChar(64)
  workerType          WorkerType
  displayName         String                  @db.VarChar(200)
  occupationFromSheet String?                 @db.VarChar(120)
  sectionFromSheet    String?                 @db.VarChar(60)
  departmentFromSheet String?                 @db.VarChar(120)
  status              AttendanceMappingStatus @default(UNMAPPED)
  resolvedEmployeeId  String?                 @db.Char(36)
  resolvedEmployee    Employee?               @relation("resolvedAttendanceCandidates", fields: [resolvedEmployeeId], references: [id])
  resolvedAt          DateTime?
  resolvedById        String?                 @db.Char(36)
  resolvedBy          User?                   @relation("AttendanceCandidateResolvedBy", fields: [resolvedById], references: [id])
  ignoredAt           DateTime?
  ignoredById         String?                 @db.Char(36)
  ignoredBy           User?                   @relation("AttendanceCandidateIgnoredBy", fields: [ignoredById], references: [id])
  ignoreReason        String?                 @db.VarChar(200)
  firstSeenAt         DateTime                @default(now())
  lastSeenAt          DateTime                @default(now())
  firstSeenSyncId     String?                 @db.Char(36)
  lastSeenSyncId      String?                 @db.Char(36)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@unique([identifier, workerType], name: "uniq_candidate_identifier")
  @@index([status])
  @@index([resolvedEmployeeId])
}

// ============================================================================
// Phase 3 (18.5.0) — Leaves, Payroll, WPS export, End-of-Service Gratuity
// ============================================================================

enum LeaveRequestStatus {
  DRAFT
  PENDING_MANAGER
  PENDING_HR
  PENDING_CEO
  APPROVED
  REJECTED
  CANCELLED
}

// 18.6.0 — origin of a leave request. NATIVE = submitted through OTS;
// DOLIBARR = mirrored from the Dolibarr `holidays` module via
// syncDolibarrLeaves. DOLIBARR rows are read-only in OTS.
enum LeaveRequestSource {
  NATIVE
  DOLIBARR
}

enum DolibarrLeaveSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum LeavePayType {
  FULLY_PAID
  HALF_PAID
  UNPAID
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
  LOCKED
}

enum WpsExportStatus {
  PENDING
  GENERATED
  DOWNLOADED
  SUBMITTED
}

// Managed catalogue of leave types (Annual, Sick, Unpaid, Hajj, Maternity,
// Emergency…). HR can add / rename / archive these from /hr/setup.
model LeaveType {
  id                         String       @id @default(uuid()) @db.Char(36)
  code                       String       @unique @db.VarChar(40)
  nameEn                     String       @db.VarChar(120)
  nameAr                     String?      @db.VarChar(120)
  payType                    LeavePayType @default(FULLY_PAID)
  monthlyAccrualDays         Decimal      @default(1.75) @db.Decimal(5, 2)
  annualAccrualDays          Decimal      @default(21) @db.Decimal(6, 2)
  maxCarryOverDays           Decimal      @default(30) @db.Decimal(6, 2)
  requiresMedicalCertificate Boolean      @default(false)
  allowNegativeBalance       Boolean      @default(true)
  countPublicHolidays        Boolean      @default(false)
  displayOrder               Int          @default(0)
  archivedAt                 DateTime?

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[] @relation("LeaveTypeBalances")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
  @@index([displayOrder])
}

// An employee's formal leave request. Approvals flow Line Manager → HR → CEO
// by default, but the active chain is configurable in SystemConfig
// (`leaves.approvalChain`). Each approver is stamped on the row so the whole
// trail is auditable.
model LeaveRequest {
  id            String             @id @default(uuid()) @db.Char(36)
  employeeId    String             @db.Char(36)
  employee      Employee           @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id])
  leaveTypeId   String             @db.Char(36)
  leaveType     LeaveType          @relation(fields: [leaveTypeId], references: [id])
  startDate     DateTime           @db.Date
  endDate       DateTime           @db.Date
  calendarDays  Int
  workingDays   Decimal            @db.Decimal(6, 2)
  reason        String?            @db.VarChar(1000)
  status        LeaveRequestStatus @default(DRAFT)
  attachmentUrl String?            @db.VarChar(500)

  // Approval trail
  submittedAt         DateTime?
  managerApprovedAt   DateTime?
  managerApprovedById String?   @db.Char(36)
  managerApprover     User?     @relation("LeaveRequestManagerApprover", fields: [managerApprovedById], references: [id])
  hrApprovedAt        DateTime?
  hrApprovedById      String?   @db.Char(36)
  hrApprover          User?     @relation("LeaveRequestHrApprover", fields: [hrApprovedById], references: [id])
  ceoApprovedAt       DateTime?
  ceoApprovedById     String?   @db.Char(36)
  ceoApprover         User?     @relation("LeaveRequestCeoApprover", fields: [ceoApprovedById], references: [id])
  rejectedAt          DateTime?
  rejectedById        String?   @db.Char(36)
  rejectedBy          User?     @relation("LeaveRequestRejectedBy", fields: [rejectedById], references: [id])
  rejectReason        String?   @db.VarChar(500)

  // Balance snapshot at submission time — so reviewing an old request shows
  // the accurate state at the time it was asked for, not today's state.
  balanceAtRequest Decimal? @db.Decimal(8, 2)
  wasOverBalance   Boolean  @default(false)

  // 18.6.0 — origin of the row. NATIVE rows are editable via the OTS UI;
  // DOLIBARR rows are synced read-only from llx_holiday and land with
  // status=APPROVED, all approver columns null. `dolibarrHolidayId` is
  // unique so the sync is idempotent.
  source            LeaveRequestSource @default(NATIVE)
  dolibarrHolidayId Int?               @unique

  createdById String    @db.Char(36)
  createdBy   User      @relation("LeaveRequestCreatedBy", fields: [createdById], references: [id])
  updatedById String?   @db.Char(36)
  updatedBy   User?     @relation("LeaveRequestUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([employeeId, status])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt])
}

// Year-to-date aggregate balance per (employee, leaveType). Recomputed by
// the balance service from LeaveRequest rows + the leave type's accrual
// rule + any manual adjustments. Cached here for fast dashboard lookups.
model LeaveBalance {
  id               String    @id @default(uuid()) @db.Char(36)
  employeeId       String    @db.Char(36)
  employee         Employee  @relation("EmployeeLeaveBalances", fields: [employeeId], references: [id])
  leaveTypeId      String    @db.Char(36)
  leaveType        LeaveType @relation("LeaveTypeBalances", fields: [leaveTypeId], references: [id])
  year             Int
  openingBalance   Decimal   @default(0) @db.Decimal(8, 2)
  accruedYtd       Decimal   @default(0) @db.Decimal(8, 2)
  usedYtd          Decimal   @default(0) @db.Decimal(8, 2)
  carriedOver      Decimal   @default(0) @db.Decimal(8, 2)
  manualAdjustment Decimal   @default(0) @db.Decimal(8, 2)
  adjustmentReason String?   @db.VarChar(500)
  asOfDate         DateTime  @db.Date
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@unique([employeeId, leaveTypeId, year])
  @@index([year])
}

// ---------------------------------------------------------------------------
// Payroll
// ---------------------------------------------------------------------------

// One period per month. Status gates what can be edited; LOCKED is terminal.
model PayrollPeriod {
  id         String              @id @default(uuid()) @db.Char(36)
  year       Int
  month      Int // 1..12
  status     PayrollPeriodStatus @default(DRAFT)
  cutoffDate DateTime            @db.Date
  payDate    DateTime            @db.Date
  notes      String?             @db.VarChar(1000)

  lines          PayrollLine[]
  adjustments    PayrollAdjustment[]
  wpsExports     WpsExport[]
  invoiceDrafts  ManpowerInvoiceDraft[]

  calculatedAt   DateTime?
  calculatedById String?   @db.Char(36)
  calculatedBy   User?     @relation("PayrollPeriodCalculatedBy", fields: [calculatedById], references: [id])
  approvedAt     DateTime?
  approvedById   String?   @db.Char(36)
  approvedBy     User?     @relation("PayrollPeriodApprovedBy", fields: [approvedById], references: [id])
  lockedAt       DateTime?
  lockedById     String?   @db.Char(36)
  lockedBy       User?     @relation("PayrollPeriodLockedBy", fields: [lockedById], references: [id])

  createdById String   @db.Char(36)
  createdBy   User     @relation("PayrollPeriodCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, month])
  @@index([status])
}

// One row per (period, employee). Stores the fully-computed payslip.
model PayrollLine {
  id         String        @id @default(uuid()) @db.Char(36)
  periodId   String        @db.Char(36)
  period     PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employeeId String        @db.Char(36)
  employee   Employee      @relation("EmployeePayrollLines", fields: [employeeId], references: [id])

  // Snapshot of employee compensation at the time of calculation
  basicSalary        Decimal @db.Decimal(12, 2)
  housingAllowance   Decimal @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  mobileAllowance    Decimal @default(0) @db.Decimal(12, 2)
  foodAllowance      Decimal @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal @default(0) @db.Decimal(12, 2)

  // Computed day / hour counters
  calendarDays                Int
  workingDays                 Int
  workedDays                  Decimal @default(0) @db.Decimal(6, 2)
  paidLeaveDays               Decimal @default(0) @db.Decimal(6, 2)
  halfPaidLeaveDays           Decimal @default(0) @db.Decimal(6, 2)
  unpaidLeaveDays             Decimal @default(0) @db.Decimal(6, 2)
  absentDaysWithPermission    Decimal @default(0) @db.Decimal(6, 2)
  absentDaysWithoutPermission Decimal @default(0) @db.Decimal(6, 2)
  publicHolidayDays           Decimal @default(0) @db.Decimal(6, 2)
  overtimeHours               Decimal @default(0) @db.Decimal(8, 2)

  dailyRate   Decimal @default(0) @db.Decimal(12, 4)
  hourlyRate  Decimal @default(0) @db.Decimal(12, 4)
  overtimePay Decimal @default(0) @db.Decimal(12, 2)

  // Deductions
  unpaidLeaveDeduction              Decimal @default(0) @db.Decimal(12, 2)
  absenceDeduction                  Decimal @default(0) @db.Decimal(12, 2)
  absenceWithPermissionDeduction    Decimal @default(0) @db.Decimal(12, 2) // 19.2.1 — absence with permission × configurable multiplier
  gosiEmployee                      Decimal @default(0) @db.Decimal(12, 2)
  gosiEmployer                      Decimal @default(0) @db.Decimal(12, 2)
  loanDeduction                     Decimal @default(0) @db.Decimal(12, 2) // 18.10.0 — sum of active loan installments
  custodyDeduction                  Decimal @default(0) @db.Decimal(12, 2) // 18.10.0 — sum of custody deduction amounts
  violationDeduction                Decimal @default(0) @db.Decimal(12, 2) // 19.2.1 — traffic violations flagged for payroll deduction
  otherDeductions                   Decimal @default(0) @db.Decimal(12, 2)

  // Additions
  bonuses        Decimal @default(0) @db.Decimal(12, 2)
  otherAdditions Decimal @default(0) @db.Decimal(12, 2)

  // Totals
  grossPay        Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @default(0) @db.Decimal(12, 2)
  totalAdditions  Decimal @default(0) @db.Decimal(12, 2)
  netPay          Decimal @default(0) @db.Decimal(12, 2)

  // Snapshot of banking for the WPS file
  bankName String? @db.VarChar(200)
  bankIban String? @db.VarChar(34)

  // Payslip PDF cache — filled when generated
  payslipPdfPath     String?   @db.VarChar(500)
  payslipGeneratedAt DateTime?

  notes String? @db.VarChar(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId, employeeId])
  @@index([employeeId])
}

// Manual additions / deductions tied to a period (bonuses, advances, fines).
// Need a reason and are audit-logged. Adding one marks the period as DRAFT
// again if it was CALCULATED, forcing a recalc before approval.
model PayrollAdjustment {
  id         String        @id @default(uuid()) @db.Char(36)
  periodId   String        @db.Char(36)
  period     PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employeeId String        @db.Char(36)
  employee   Employee      @relation("EmployeePayrollAdjustments", fields: [employeeId], references: [id])
  kind       String        @db.VarChar(40) // BONUS | DEDUCTION | ADVANCE_REPAYMENT | FINE | OTHER | ANNUAL_LEAVE_ALLOWANCE | TICKET_ALLOWANCE | EXIT_REENTRY_VISA
  amount     Decimal       @db.Decimal(12, 2) // always positive; `kind` dictates sign
  reason     String        @db.VarChar(500)
  leaveDaysCompensated Decimal? @db.Decimal(6, 2) // populated for ANNUAL_LEAVE_ALLOWANCE; days deducted from leave balance

  createdById String    @db.Char(36)
  createdBy   User      @relation("PayrollAdjustmentCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([periodId])
  @@index([employeeId])
  @@index([deletedAt])
}

// One WPS file per approved payroll period. Alinma Bank uses a standard
// SAMA-compliant CSV; the file path stores the rendered file on disk.
model WpsExport {
  id             String          @id @default(uuid()) @db.Char(36)
  periodId       String          @db.Char(36)
  period         PayrollPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  bankCode       String          @db.VarChar(20) // ALINMA
  fileFormat     String          @db.VarChar(20) // CSV
  filename       String          @db.VarChar(255)
  filePath       String          @db.VarChar(500)
  totalEmployees Int
  totalNet       Decimal         @db.Decimal(14, 2)
  status         WpsExportStatus @default(GENERATED)

  generatedById  String    @db.Char(36)
  generatedBy    User      @relation("WpsExportGeneratedBy", fields: [generatedById], references: [id])
  generatedAt    DateTime  @default(now())
  downloadedAt   DateTime?
  downloadedById String?   @db.Char(36)

  @@index([periodId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 18.10.0 — Loans & Custodies (Phase 3 — Payroll Engine)
// ---------------------------------------------------------------------------

enum LoanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PENDING_APPROVAL
}

enum CustodyStatus {
  OPEN
  PARTIALLY_SETTLED
  SETTLED
}

// Employee loan. Deducted from payroll in equal monthly installments.
// Warning flag required when installmentsTotal > 12 (HR policy).
model Loan {
  id                String     @id @default(uuid()) @db.Char(36)
  employeeId        String     @db.Char(36)
  employee          Employee   @relation("EmployeeLoans", fields: [employeeId], references: [id])
  principal         Decimal    @db.Decimal(12, 2)
  installmentAmount Decimal    @db.Decimal(12, 2)
  installmentsTotal Int
  installmentsPaid  Int        @default(0)
  startDate         DateTime   @db.Date
  status            LoanStatus @default(ACTIVE)
  reason            String?    @db.VarChar(500)

  // HR policy: loans spanning > 12 months require an explicit warning + reason
  exceedsYearWarning Boolean @default(false)
  warningReason      String? @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("LoanCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("LoanUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("LoanDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  payments     LoanPayment[] @relation("LoanPayments")

  @@index([employeeId, status])
  @@index([deletedAt])
}

// Individual payment event against a Loan (manual or payroll-deducted).
model LoanPayment {
  id          String   @id @default(uuid()) @db.Char(36)
  loanId      String   @db.Char(36)
  loan        Loan     @relation("LoanPayments", fields: [loanId], references: [id])

  paymentType String   @default("SCHEDULED") @db.VarChar(20) // SCHEDULED | ADJUSTED
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @db.Date
  notes       String?  @db.VarChar(500)

  createdById String   @db.Char(36)
  createdBy   User     @relation("LoanPaymentCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([loanId])
  @@index([paymentDate])
}

// Employee custody (cash advance / company asset). Finance can set
// `deductionAmount` on the row to trigger a deduction in the next payroll
// run. Setting it to 0 pauses deduction. Status auto-updates from OPEN →
// PARTIALLY_SETTLED → SETTLED as settledAmount reaches amount.
model Custody {
  id              String        @id @default(uuid()) @db.Char(36)
  employeeId      String        @db.Char(36)
  employee        Employee      @relation("EmployeeCustodies", fields: [employeeId], references: [id])
  amount          Decimal       @db.Decimal(12, 2)
  issuedDate      DateTime      @db.Date
  reason          String        @db.VarChar(500)
  settledAmount   Decimal       @default(0) @db.Decimal(12, 2)
  deductionAmount Decimal       @default(0) @db.Decimal(12, 2) // amount to deduct per payroll run; 0 = paused
  status          CustodyStatus @default(OPEN)
  notes           String?       @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("CustodyCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("CustodyUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("CustodyDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([employeeId, status])
  @@index([deletedAt])
}

// ─── Asset Management (18.12.0) ──────────────────────────────────────────────

enum AssetCategory {
  CAR
  SIM_CARD
  LAPTOP
  TABLET
  PHONE
  KEY
  TOOL
  EQUIPMENT
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_MAINTENANCE
  RETIRED
  DAMAGED
  LOST
}

enum AssetAssignmentStatus {
  ACTIVE
  RETURNED
}

enum AssetReturnReason {
  VACATION
  RESIGNATION
  TERMINATION
  TRANSFER
  MAINTENANCE
  EXPIRED
  PROJECT_END
  OTHER
}

enum ViolationStatus {
  PENDING
  PAID_BY_EMPLOYEE
  PAID_BY_COMPANY
  DEDUCTED_FROM_PAYROLL
}

enum MaintenanceType {
  OIL_CHANGE
  BRAKE_SERVICE
  TIRE_ROTATION
  TIRE_REPLACEMENT
  BATTERY_REPLACEMENT
  AC_SERVICE
  GENERAL_SERVICE
  INSPECTION
  REPAIR
  ACCIDENT_REPAIR
  FILTER_REPLACEMENT
  SPARK_PLUGS
  TRANSMISSION_SERVICE
  COOLANT_FLUSH
  OTHER
}

// Master asset registry. Each physical item (car, SIM card, laptop, key, etc.)
// gets a single Asset row. Assignments track who holds it and when.
model Asset {
  id        String        @id @default(uuid()) @db.Char(36)
  assetSn   Int?          @unique
  assetCode String        @unique @db.VarChar(50)
  name      String        @db.VarChar(200)
  category AssetCategory
  status   AssetStatus   @default(AVAILABLE)

  // Car-specific fields
  plateNumber   String? @db.VarChar(30)
  vehicleMake   String? @db.VarChar(100)
  vehicleModel  String? @db.VarChar(100)
  vehicleYear   Int?
  vehicleColor  String? @db.VarChar(50)
  vin           String? @db.VarChar(50)
  currentOdometer Int?  // km

  // SIM-specific
  simNumber    String? @db.VarChar(30)
  mobileNumber String? @db.VarChar(30)
  carrier      String? @db.VarChar(100)

  // General fields (all categories)
  serialNumber      String?   @db.VarChar(100)
  make              String?   @db.VarChar(100)
  model             String?   @db.VarChar(100)
  purchaseDate      DateTime? @db.Date
  purchasePrice     Decimal?  @db.Decimal(12, 2)
  location          String?   @db.VarChar(200) // Physical location / storage / site (18.18.1)
  notes             String?   @db.Text
  licenseExpiryDate DateTime? @db.Date // car registration/license expiry
  attachments       Json?     // Array of {fileName, filePath, fileType, fileSize, uploadedAt, label?}

  assignments        AssetAssignment[]      @relation("AssetAssignments")
  maintenanceRecords CarMaintenanceRecord[] @relation("AssetMaintenanceRecords")
  violations         TrafficViolation[]     @relation("AssetViolations")

  createdById  String    @db.Char(36)
  createdBy    User      @relation("AssetCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("AssetUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("AssetDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([category, status])
  @@index([deletedAt])
}

// Time-range assignment of an Asset to an Employee.
// returnedDate=null means the employee currently holds the asset.
model AssetAssignment {
  id           String                @id @default(uuid()) @db.Char(36)
  assetId      String                @db.Char(36)
  asset        Asset                 @relation("AssetAssignments", fields: [assetId], references: [id])
  employeeId   String                @db.Char(36)
  employee     Employee              @relation("EmployeeAssetAssignments", fields: [employeeId], references: [id])
  assignedDate DateTime              @db.Date
  returnedDate DateTime?             @db.Date
  status       AssetAssignmentStatus @default(ACTIVE)
  returnReason AssetReturnReason?
  notes        String?               @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("AssetAssignmentCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("AssetAssignmentUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("AssetAssignmentDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([assetId, status])
  @@index([employeeId, status])
  @@index([deletedAt])
}

// Traffic violation / fine linked to an employee and optionally a company car.
// When deductFromPayroll=true the payroll calculator will deduct violationAmount
// from the employee's next payslip once status=PAID_BY_COMPANY.
model TrafficViolation {
  id               String          @id @default(uuid()) @db.Char(36)
  employeeId       String          @db.Char(36)
  employee         Employee        @relation("EmployeeViolations", fields: [employeeId], references: [id])
  assetId          String?         @db.Char(36)
  asset            Asset?          @relation("AssetViolations", fields: [assetId], references: [id])
  violationDate    DateTime        @db.Date
  violationType    String          @db.VarChar(200)
  violationAmount  Decimal         @db.Decimal(12, 2)
  status           ViolationStatus @default(PENDING)
  referenceNumber  String?         @db.VarChar(100)
  issuingAuthority String?         @db.VarChar(200)
  deductFromPayroll Boolean        @default(false)
  notes            String?         @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("ViolationCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("ViolationUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("ViolationDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([employeeId, violationDate])
  @@index([assetId])
  @@index([deletedAt])
}

// Comprehensive maintenance log for company vehicles.
model CarMaintenanceRecord {
  id                  String          @id @default(uuid()) @db.Char(36)
  assetId             String          @db.Char(36)
  asset               Asset           @relation("AssetMaintenanceRecords", fields: [assetId], references: [id])
  maintenanceDate     DateTime        @db.Date
  maintenanceType     MaintenanceType
  description         String          @db.VarChar(500)
  serviceCenter       String?         @db.VarChar(200)
  odometer            Int?            // km at time of service
  cost                Decimal?        @db.Decimal(12, 2)
  nextServiceDate     DateTime?       @db.Date
  nextServiceOdometer Int?            // km for next service
  partsReplaced       String?         @db.VarChar(500)
  invoiceNumber       String?         @db.VarChar(100)
  technician          String?         @db.VarChar(200)
  notes               String?         @db.Text

  createdById  String    @db.Char(36)
  createdBy    User      @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("MaintenanceUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("MaintenanceDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([assetId, maintenanceDate])
  @@index([deletedAt])
}

// Recorded snapshot of the End-of-Service gratuity for a terminated employee.
// Saudi labour law formula: 0.5 month per year of the first 5 years, then
// 1 month per year thereafter. A partial year is prorated.
model EndOfServiceAward {
  id               String   @id @default(uuid()) @db.Char(36)
  employeeId       String   @unique @db.Char(36)
  employee         Employee @relation("EmployeeEosAward", fields: [employeeId], references: [id])
  serviceStartDate DateTime @db.Date
  serviceEndDate   DateTime @db.Date
  serviceYears     Decimal  @db.Decimal(6, 3)
  lastMonthlyWage  Decimal  @db.Decimal(12, 2)
  firstTierMonths  Decimal  @db.Decimal(8, 3) // up-to 2.5 (0.5 × 5 years)
  secondTierMonths Decimal  @db.Decimal(8, 3)
  grossAward       Decimal  @db.Decimal(14, 2)
  deductions       Decimal  @default(0) @db.Decimal(14, 2)
  netAward         Decimal  @db.Decimal(14, 2)
  notes            String?  @db.VarChar(1000)

  calculatedById String    @db.Char(36)
  calculatedBy   User      @relation("EndOfServiceCalculatedBy", fields: [calculatedById], references: [id])
  calculatedAt   DateTime  @default(now())
  paidAt         DateTime?
  paidById       String?   @db.Char(36)
  paidBy         User?     @relation("EndOfServicePaidBy", fields: [paidById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Phase 4 — Manpower Billing & Attendance Archive Integration
// Auto-generate one vendor invoice draft per agency when a payroll period is
// approved. HR reviews/adjusts before pushing to Dolibarr as a supplier invoice.
// ============================================================================

enum InvoiceDraftStatus {
  DRAFT     // generated, awaiting HR review
  CONFIRMED // HR approved — ready to push
  PUSHED    // Dolibarr supplier invoice created (dolibarrInvoiceId populated)
  PAID      // marked paid (reconciled)
}

// One draft invoice per agency per payroll period
model ManpowerInvoiceDraft {
  id              String             @id @default(uuid()) @db.Char(36)
  agencyId        String             @db.Char(36)
  agency          Agency             @relation(fields: [agencyId], references: [id])
  payrollPeriodId String             @db.Char(36)
  payrollPeriod   PayrollPeriod      @relation(fields: [payrollPeriodId], references: [id])
  periodStart     DateTime           @db.Date
  periodEnd       DateTime           @db.Date
  status          InvoiceDraftStatus @default(DRAFT)

  totalHours  Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(14, 2)

  // Populated when pushed to Dolibarr (supplier invoice ref)
  dolibarrInvoiceId  String?   @db.VarChar(40)
  dolibarrInvoiceRef String?   @db.VarChar(80) // Dolibarr's human-readable ref
  pushedAt           DateTime?

  notes String? @db.VarChar(1000)

  lines ManpowerInvoiceLine[]

  createdById  String    @db.Char(36)
  createdBy    User      @relation("ManpowerInvoiceDraftCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("ManpowerInvoiceDraftUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("ManpowerInvoiceDraftDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@unique([agencyId, payrollPeriodId]) // one draft per agency per period
  @@index([agencyId, status])
  @@index([payrollPeriodId])
  @@index([status])
  @@index([deletedAt])
}

// 18.14.0 — Contracts & Documents Management

enum ContractType {
  HEALTH_INSURANCE
  MEDICAL_INSURANCE
  IQAMA
  CAR_REGISTRATION
  VEHICLE_LICENSE
  PROFESSIONAL_LICENSE
  COMMERCIAL_REGISTRATION
  LEGAL_DOCUMENT
  OTHER
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  PENDING_RENEWAL
  CANCELLED
}

model Contract {
  id               String         @id @default(uuid()) @db.Char(36)
  contractNumber   String         @unique @db.VarChar(30)
  title            String         @db.VarChar(300)
  type             ContractType
  employeeId       String?        @db.Char(36)
  employee         Employee?      @relation("EmployeeContracts", fields: [employeeId], references: [id])
  issuingAuthority String?        @db.VarChar(200)
  referenceNumber  String?        @db.VarChar(100)
  issueDate        DateTime?      @db.Date
  expiryDate       DateTime?      @db.Date
  expiryDateHijri  String?        @db.VarChar(20)
  status           ContractStatus @default(ACTIVE)
  notifyDaysBefore Int            @default(30)
  description      String?        @db.Text
  filePath         String?        @db.VarChar(500)

  createdById  String    @db.Char(36)
  createdBy    User      @relation("ContractCreatedBy", fields: [createdById], references: [id])
  updatedById  String?   @db.Char(36)
  updatedBy    User?     @relation("ContractUpdatedBy", fields: [updatedById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?   @db.Char(36)
  deletedBy    User?     @relation("ContractDeletedBy", fields: [deletedById], references: [id])
  deleteReason String?   @db.VarChar(500)

  @@index([type, status])
  @@index([employeeId])
  @@index([expiryDate])
  @@index([deletedAt])
  @@map("Contract")
}

// One line per manpower slot in the draft invoice
model ManpowerInvoiceLine {
  id             String               @id @default(uuid()) @db.Char(36)
  invoiceDraftId String               @db.Char(36)
  invoiceDraft   ManpowerInvoiceDraft @relation(fields: [invoiceDraftId], references: [id], onDelete: Cascade)
